{
  "name": "classpro-desktop",
  "version": "1.0.0",
  "description": "ClassPro Desktop — Logiciel parent de ClassPro",
  "main": "src/main/main.js",
  "author": {
    "name": "Lucas Le Coadou",
    "email": "lucas.le-coadou@ac-montpellier.fr"
  },
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder --win --mac"
  },
  "dependencies": {
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2"
  },
  "devDependencies": {
    "electron": "^41.0.3",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "fr.lucaslecoadou.classpro-desktop",
    "productName": "ClassPro Desktop",
    "copyright": "© 2025 Lucas Le Coadou",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "!assets/icon-src/**",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "artifactName": "ClassPro-Desktop-Setup-${version}.exe"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.education",
      "artifactName": "ClassPro-Desktop-${version}-${arch}.dmg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "installerLanguages": [
        "French"
      ],
      "language": "1036",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ClassPro Desktop",
      "installerHeader": "assets/nsis-header.bmp",
      "deleteAppDataOnUninstall": false
    },
    "dmg": {
      "title": "ClassPro Desktop ${version}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    }
  }
}
